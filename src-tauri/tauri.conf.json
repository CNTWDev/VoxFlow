{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vox Flow",
  "version": "0.1.0",
  "identifier": "com.voxflow.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Vox Flow",
        "width": 1120,
        "height": 780,
        "minWidth": 860,
        "minHeight": 700,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "infoPlist": {
        "NSInputMonitoringUsageDescription": "用于监听 Fn 按键，开始和结束录音。",
        "NSAccessibilityUsageDescription": "用于把转写的文字粘贴到当前焦点应用。",
        "NSMicrophoneUsageDescription": "用于录制语音并进行语音识别。"
      }
    }
  }
}
